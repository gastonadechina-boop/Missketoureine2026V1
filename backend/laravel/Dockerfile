# Pour démarrer le projet localement sans Docker :
#   1. cp .env.example .env
#   2. php artisan key:generate
#   3. php artisan migrate
#   4. php artisan serve
#
# Ce fichier ne doit PAS être utilisé pour un build ou un déploiement.
