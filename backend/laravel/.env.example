APP_NAME=MissKetouReine
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── BASE DE DONNÉES LOCALE ────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=missketoureine_local
DB_USERNAME=root
DB_PASSWORD=

# ─── SESSION ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=localhost

# ─── CORS / FRONTEND (local) ──────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS_PATTERN=.*
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# ─── BROADCAST / FILESYSTEM / QUEUE ───────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ─── CACHE ────────────────────────────────────────────────────────────────────
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── MAIL (log local uniquement) ──────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@local.test"
MAIL_FROM_NAME="${APP_NAME}"

# ─── ADMIN LOCAL ──────────────────────────────────────────────────────────────
LOCAL_ADMIN_NAME=
LOCAL_ADMIN_EMAIL=
LOCAL_ADMIN_PHONE=
LOCAL_ADMIN_PASSWORD=
LOCAL_ADMIN_ROLE=superadmin
LOCAL_ADMIN_STATUS=active

# ─── AWS (non utilisé en local) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_REKOGNITION_VERSION=latest

# ─── MEDIA ────────────────────────────────────────────────────────────────────
MEDIA_DRIVER=local
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=missketoureine
CLOUDINARY_TIMEOUT=30

# ─── FEDAPAY (sandbox uniquement — aucune clé live) ───────────────────────────
FEDAPAY_PUBLIC_KEY=pk_sandbox_REMPLACER_PAR_CLE_TEST
FEDAPAY_SECRET_KEY=sk_sandbox_REMPLACER_PAR_CLE_TEST
FEDAPAY_WEBHOOK_SECRET=wh_sandbox_REMPLACER_PAR_CLE_TEST
FEDAPAY_ENVIRONMENT=sandbox
FEDAPAY_WEBHOOK_ASYNC=true
FEDAPAY_WEBHOOK_QUEUE=default
FEDAPAY_READ_MODEL_WARM_ENABLED=false
FEDAPAY_AUDIT_IGNORE_REFERENCES=

# ─── IMAGES CANDIDATS ─────────────────────────────────────────────────────────
CANDIDATE_IMAGE_DISK=public
CANDIDATE_IMAGE_QUEUE=images
CANDIDATE_IMAGE_ASYNC_PROCESSING=false
CANDIDATE_IMAGE_FACE_PROVIDER=none
CANDIDATE_IMAGE_REQUIRE_FACE=false
CANDIDATE_IMAGE_MIN_WIDTH=500
CANDIDATE_IMAGE_MIN_HEIGHT=500
CANDIDATE_IMAGE_BLUR_THRESHOLD=15
CANDIDATE_IMAGE_WEBP_QUALITY=92
CANDIDATE_IMAGE_BACKGROUND_COLOR=#000000

VITE_APP_NAME="${APP_NAME}"
